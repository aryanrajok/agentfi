# ============================================
# AgentFi Environment Variables
# Copy this file to .env and fill in your values
# ============================================

# --- Network Configuration ---
# Set to "mainnet" or "testnet"
VITE_NETWORK=testnet

# BNB Chain RPC URLs
VITE_BNB_MAINNET_RPC=https://bsc-dataseed.binance.org/
VITE_BNB_TESTNET_RPC=https://data-seed-prebsc-1-s1.binance.org:8545/

# --- Smart Contract Deployment ---
# Private key for deploying contracts (WITHOUT 0x prefix)
# NEVER commit this value. Use a dedicated deployer wallet.
DEPLOYER_PRIVATE_KEY=

# --- WDK Configuration ---
# BIP-39 seed phrase for WDK wallet derivation
# Generate one at: https://iancoleman.io/bip39/
WDK_SEED=

# WDK Indexer API key (optional, enables indexer tools)
# Get one at: https://wdk-api.tether.io/register
WDK_INDEXER_API_KEY=

# --- Optional: MoonPay (Fiat on/off ramp) ---
MOONPAY_API_KEY=
MOONPAY_SECRET_KEY=

# --- Supabase (Storage & Database) ---
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_anon_key
